{
  "rules": {
    "sessions": {
      ".read": false,
      ".write": false,
      "$code": {

        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('facilitatorUid').val() === auth.uid)",
          ".validate": "newData.hasChildren(['createdAt','facilitatorUid']) && newData.child('facilitatorUid').val() === auth.uid"
        },

        "content": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('sessions').child($code).child('meta/facilitatorUid').val() === auth.uid"
        },

        "answers": {
          ".read": "auth != null && root.child('sessions').child($code).child('meta/facilitatorUid').val() === auth.uid",
          "$pushId": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.hasChildren(['vals','at','name','naamZichtbaar']) && newData.child('name').isString() && newData.child('name').val().length <= 120 && newData.child('naamZichtbaar').isBoolean() && (!newData.hasChild('email') || (newData.child('email').isString() && newData.child('email').val().length <= 200)) && newData.child('vals').hasChildren()",
            "vals": {
              "$lv": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" }
            }
          }
        },

        "state": {
          ".read": "auth != null && root.child('sessions').child($code).child('meta/facilitatorUid').val() === auth.uid",
          ".write": "auth != null && root.child('sessions').child($code).child('meta/facilitatorUid').val() === auth.uid"
        }
      }
    }
  }
}
