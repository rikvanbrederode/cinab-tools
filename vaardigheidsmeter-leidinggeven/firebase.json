{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/join/**",
        "destination": "/vaardigheidsmeter_join.html"
      }
    ],
    "headers": [
      {
        "source": "/vaardigheidsmeter_rapport.html",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors 'self' https://cinab.nl https://staging2.cinab.nl https://*.cinab.nl"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
